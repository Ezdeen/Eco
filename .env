# Development environment - SQLite for local dev
# For production: change prisma/schema.prisma provider to "postgresql"
# and set DATABASE_URL=postgresql://user:pass@host:5432/esg_solar?schema=public
DATABASE_URL=file:/home/z/my-project/db/custom.db

# JWT_SECRET - REQUIRED, no default fallback in production
# Generate with: openssl rand -base64 32
JWT_SECRET=dev-only-insecure-secret-change-in-production-min32chars

# Node environment
NODE_ENV=development

# Hedera configuration
# Options: simulation (dev only), testnet, mainnet
# In production: must be testnet or mainnet (simulation is blocked)
HEDERA_NETWORK=simulation
# HEDERA_OPERATOR_ID=0.0.xxxx
# HEDERA_OPERATOR_KEY=302e020100300506032b657004220420xxxx
# HEDERA_TOPIC_ID=0.0.xxxx
