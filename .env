# Development environment - SQLite for local dev
# For production: change prisma/schema.prisma provider to "postgresql"
# and set DATABASE_URL=postgresql://user:pass@host:5432/esg_solar?schema=public
#
# NOTE: schema.prisma is set to postgresql. To use SQLite locally,
# temporarily change provider to "sqlite" and use this URL:
DATABASE_URL=file:../db/custom.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/esg_solar?schema=public

# JWT_SECRET - REQUIRED, must be at least 32 characters
JWT_SECRET=esg-solar-platform-jwt-secret-2026-stable-do-not-change

# Node environment
NODE_ENV=development

# Hedera configuration
HEDERA_NETWORK=simulation
# HEDERA_OPERATOR_ID=0.0.xxxx
# HEDERA_OPERATOR_KEY=302e020100300506032b657004220420xxxx
# HEDERA_TOPIC_ID=0.0.xxxx

# n8n Webhook Secret (for HMAC verification)
# N8N_WEBHOOK_SECRET=your-secret-here
