# Database configuration - Supabase (PostgreSQL)
# Ensure your prisma/schema.prisma provider is set to "postgresql"
# !! غيّر كلمة السر من لوحة Supabase قبل الاستخدام — القديمة كانت مكشوفة على GitHub !!

# 1. Transaction pooler (Supavisor) - يستخدمه التطبيق وقت التشغيل. المنفذ 6543 + pgbouncer=true
#    صيغة اسم المستخدم لازم تكون postgres.PROJECT_REF وليس postgres فقط
DATABASE_URL=postgresql://postgres.ecadtabmiagvuumrzxxb:SEfPn4keOrYgCsPO@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# 2. Session pooler (Supavisor) - يستخدمه Prisma لـ migrate/introspect. المنفذ 5432، بدون pgbouncer=true
#    استخدم هذا بدل الاتصال المباشر (db.xxx.supabase.co) لتفادي مشاكل IPv6-only
DIRECT_URL=postgresql://postgres.ecadtabmiagvuumrzxxb:SEfPn4keOrYgCsPO@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# JWT_SECRET - REQUIRED, must be at least 32 characters
JWT_SECRET="esg-solar-platform-jwt-secret-2026-stable-do-not-change"

# Node environment
NODE_ENV="development"

# Hedera configuration (testnet/simulation for automated hashing workflows)
HEDERA_NETWORK="testnet" 
# HEDERA_OPERATOR_ID=0.0.xxxx
# HEDERA_OPERATOR_KEY=302e020100300506032b657004220420xxxx
# HEDERA_TOPIC_ID=0.0.xxxx

# n8n Webhook Secret (for HMAC verification)
# N8N_WEBHOOK_SECRET="your-secret-here"
